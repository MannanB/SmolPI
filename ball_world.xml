<mujoco model="two_wheel_camera_bot_ball_world">
  <compiler angle="degree" coordinate="local"/>
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1280" offheight="960"/>
    <rgba haze="0 0 0 0"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.2 0.2 0.2" rgb2="0.8 0.8 0.8"/>
    <material name="gridmat" texture="grid" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 5.5" dir="0 0 -1" diffuse="0.32 0.32 0.32" ambient="0.12 0.12 0.12"/>
    <light pos="5 -4 6" dir="-0.9 0.2 -1" diffuse="0.2 0.2 0.2"/>
    <light pos="-5 4 6" dir="0.9 -0.2 -1" diffuse="0.2 0.2 0.2"/>
    <light pos="5 4 6" dir="-0.7 -0.7 -1" diffuse="0.16 0.16 0.16"/>
    <light pos="-5 -4 6" dir="0.7 0.7 -1" diffuse="0.16 0.16 0.16"/>

    <geom name="floor" type="plane" size="20 20 0.1"
          material="gridmat" friction="1.2 0.1 0.1"/>

    <!-- Omni camera copied from current ball world -->
    <camera name="omniscient_cam"
            pos="-4.2 -5.0 5.4"
            xyaxes="0.77 -0.64 0 0.34 0.41 0.84"
            fovy="75"/>

    <geom name="red_box" type="box" pos="3 0 0.25" size="0.25 0.25 0.25"
          rgba="1 0.1 0.1 1"/>

    <include file="robot.xml"/>

    <body name="sphere_01" pos="1.4 -0.4 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.95 0.25 0.25 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_02" pos="1.5 -0.15 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.22 0.8 0.35 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_03" pos="1.45 0.1 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.2 0.45 0.95 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_04" pos="1.6 0.35 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.95 0.78 0.2 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_05" pos="1.8 -0.3 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.8 0.3 0.95 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_06" pos="1.85 -0.05 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.2 0.85 0.85 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_07" pos="1.9 0.22 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.95 0.5 0.2 1" friction="0.8 0.03 0.03"/>
    </body>
    <body name="sphere_08" pos="2.05 0.5 0.09">
      <freejoint/>
      <geom type="sphere" size="0.09" mass="0.4" rgba="0.55 0.95 0.3 1" friction="0.8 0.03 0.03"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="left_motor" joint="left_wheel_joint" gear="1" ctrllimited="true" ctrlrange="-5 5"/>
    <motor name="right_motor" joint="right_wheel_joint" gear="1" ctrllimited="true" ctrlrange="-5 5"/>
  </actuator>
</mujoco>
