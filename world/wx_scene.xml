<mujoco model="wx250s scene">
  <include file="wx250s.xml"/>

  <statistic center="0 0 0.12" extent="0.4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-30" offwidth="1024" offheight="512"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <camera name="scene_cam" mode="targetbody" target="red_box" pos="0.62 -0.50 0.52" fovy="48"/>
    <!-- Mirror of Bridge's elevated fixed depth camera, mounted on the
         robot's right side and aimed inward at the manipulation area. -->
    <camera name="scene_cam_2" mode="fixed" pos="0.10 -0.25 0.40"
      xyaxes="0.721387 -0.692532 0 0.508604 0.529796 0.678704" fovy="45"/>

    <!-- A compact kitchen-style work table puts the manipulation area above
         the floor and gives the cameras a bounded work surface like Bridge. -->
    <body name="work_table">
      <geom name="worktop" type="box" pos="0.32 0 0.10" size="0.27 0.25 0.015"
        rgba="0.56 0.38 0.23 1" friction="1.2 0.01 0.001"/>
      <geom name="table_leg_front_left" type="box" pos="0.08 -0.21 0.0425"
        size="0.025 0.025 0.0425" rgba="0.16 0.14 0.12 1"/>
      <geom name="table_leg_front_right" type="box" pos="0.08 0.21 0.0425"
        size="0.025 0.025 0.0425" rgba="0.16 0.14 0.12 1"/>
      <geom name="table_leg_back_left" type="box" pos="0.56 -0.21 0.0425"
        size="0.025 0.025 0.0425" rgba="0.16 0.14 0.12 1"/>
      <geom name="table_leg_back_right" type="box" pos="0.56 0.21 0.0425"
        size="0.025 0.025 0.0425" rgba="0.16 0.14 0.12 1"/>
    </body>

    <body name="red_box" pos="0.34 0 0.025">
      <freejoint name="red_box_freejoint"/>
      <geom name="red_box_geom" type="box" size="0.025 0.025 0.025"
        mass="0.045" rgba="0.9 0.02 0.02 1" friction="1.2 0.01 0.001"/>
    </body>
    <body name="blue_box" pos="0.34 -0.08 0.025">
      <freejoint name="blue_box_freejoint"/>
      <geom name="blue_box_geom" type="box" size="0.025 0.025 0.025"
        mass="0.045" rgba="0.02 0.1 0.9 1" friction="1.2 0.01 0.001"/>
    </body>
    <body name="green_box" pos="0.34 0.08 0.025">
      <freejoint name="green_box_freejoint"/>
      <geom name="green_box_geom" type="box" size="0.025 0.025 0.025"
        mass="0.045" rgba="0.02 0.75 0.08 1" friction="1.2 0.01 0.001"/>
    </body>
  </worldbody>
</mujoco>
